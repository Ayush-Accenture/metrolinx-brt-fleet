# ── Azure AI Foundry ─────────────────────────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://pds-dev-agenticai-dashboard-azureopenai-foundry.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=pds-dev-agenticai-project-gpt-5.4-nano
# AZURE_OPENAI_API_VERSION=2024-10-21

# Required once Azure AI Developer role is assigned:
# FOUNDRY_PROJECT_CONNECTION_STRING=<eastus.api.azureml.ms;...>

# ── SOTI MCP Server ──────────────────────────────────────────────────────────
# SOTI_MCP_TRANSPORT=stdio
# SOTI_MCP_COMMAND=python
# SOTI_MCP_ARGS=-m soti_mcp_server
# SOTI_MCP_HTTP_URL=http://localhost:8000/mcp

# ── Mock flags ───────────────────────────────────────────────────────────────
# USE_MOCK_LLM=true       # Set false when OpenAI User role lands
# USE_MOCK_SOTI=true      # Set false when soti_mcp_server confirmed working
# USE_MOCK_HITL=false     # Set true for unattended / CI runs
# USE_MOCK_COSMOS=true    # Set false when Cosmos DB Contributor role lands

# ── Cosmos DB for MongoDB vCore ──────────────────────────────────────────────
# COSMOS_CONNECTION_STRING=mongodb+srv://<user>:<password>@<host>/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000
# COSMOS_DATABASE=fmi-db
# COSMOS_INTAKE_COLLECTION=intake

# ── Paths ────────────────────────────────────────────────────────────────────
# STATE_DIR=state
# SAMPLE_DVA=samples/sample_dva.xlsx
