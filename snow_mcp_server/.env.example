# Copy this file to `.env` and fill in the values. NEVER commit the real `.env`.

# Base URL of the ServiceNow instance, INCLUDING the trailing /api
# (snow_client.py appends /now/table/... and /now/v1/... on top of this).
SNOW_API_BASE_URL=https://<your-instance>.service-now.com/api

# Service account credentials
SNOW_USERNAME=
SNOW_PASSWORD=

# sys_id of the "Device Monitoring" Service Catalog item that is ORDERED to
# raise the Ad-hoc SR. Ordering it auto-creates the REQ + RITM (+ SCTASK).
# >>> THIS IS THE ONE VALUE STILL NEEDED — fill it once SNOW provides it. <<<
SNOW_CATALOG_ITEM_SYS_ID=

# sys_id (or user id) the SR is "Requested for".
SNOW_REQUESTED_FOR=

# Optional MCP server bind settings
MCP_HOST=0.0.0.0
MCP_PORT=8000
