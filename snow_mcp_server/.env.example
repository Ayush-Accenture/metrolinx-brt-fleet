# Copy this file to `.env` and fill in the values. NEVER commit the real `.env`.

# Base URL of the ServiceNow instance, INCLUDING the trailing /api
# (snow_client.py appends /now/table/... and /now/v1/... on top of this).
SNOW_API_BASE_URL=https://<your-instance>.service-now.com/api

# Service account credentials
SNOW_USERNAME=
SNOW_PASSWORD=

# ── Catalog item identification (choose ONE option) ───────────────────────────
#
# Option A — If you know the sys_id, set it directly.
#   How to find it: open the catalog item in SNOW → right-click form header
#   → "Copy sys_id".  It is a 32-character hex string.
SNOW_CATALOG_ITEM_SYS_ID=
#
# Option B — If you don't know the sys_id, set the display name instead.
#   The code will query sc_cat_item at runtime to find the sys_id automatically.
#   If multiple items match the name, startup will fail and print all matches
#   with their sys_ids so you can pick the right one and set Option A above.
SNOW_CATALOG_ITEM_NAME=Device Monitoring
#
# NOTE: Option A takes priority if both are set.
# ─────────────────────────────────────────────────────────────────────────────

# SNOW username or sys_id for the "Requested for" field on the SR.
# Fully optional — if empty, SNOW defaults to the authenticated service account.
# Set this only if you need the SR attributed to a specific SNOW user (not the service account).
# Note: this is a SNOW user identifier, NOT the display name shown in fleet.xlsx.
SNOW_REQUESTED_FOR=

# Optional MCP server bind settings
MCP_HOST=0.0.0.0
MCP_PORT=8000
