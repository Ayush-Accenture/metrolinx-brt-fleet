      "command": "python",
      "args": ["server.py"],
      "cwd": "/path/to/soti-mcp-server",
      "env": {
        "SOTI_BASE_URL":       "https://20.220.205.86/MobiControl/api",
        "SOTI_USERNAME":       "<your_username>",
