# Cosmos DB (MongoDB vCore) — the SAME database as intake/movement.
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE=fmi-db
COSMOS_RUNS_COLLECTION=runs

# Keep true to run with sample data (no DB needed). Flip to false once the
# orchestrator writes run docs to the Cosmos `runs` collection (agent-side change).
USE_MOCK_COSMOS=true

PORT=8080
